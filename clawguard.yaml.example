server:
  port: 9090
  agentKey: "change-me-to-a-random-string"    # IMPORTANT: openssl rand -hex 24

services:
  # ─── Safe test service (start here!) ────────────────────
  # No signup needed. httpbin.org echoes your request back,
  # so you can verify ClawGuard injects the token correctly.
  httpbin:
    upstream: https://httpbin.org
    auth:
      type: bearer
      token: "test-secret-token-12345"   # fake token — httpbin echoes it back
    policy:
      default: require_approval

  # ─── GitHub (the real reason you need ClawGuard) ────────
  # Imagine a prompt injection tries: DELETE /repos/you/important-repo
  # Without ClawGuard: repo deleted. With ClawGuard: you tap Deny.
  github:
    upstream: https://api.github.com
    auth:
      type: bearer
      token: "ghp_your-github-token"
    policy:
      default: require_approval
      rules:
        - match: { method: GET }
          action: auto_approve              # reads pass through
        - match: { method: POST }
          action: require_approval          # writes need your OK
        - match: { method: DELETE }
          action: require_approval          # deletes DEFINITELY need your OK

  # ─── OpenAI (with host-based routing for forwarder) ─────
  openai:
    upstream: https://api.openai.com
    hostnames:                              # optional: for /etc/hosts or forwarder mode
      - api.openai.com
    auth:
      type: bearer
      token: "sk-your-openai-key-here"
    policy:
      default: require_approval
      rules:
        - match: { method: GET }
          action: auto_approve
        - match: { method: POST }
          action: require_approval

  # ─── OAuth2 service (e.g. Stripe) ──────────────────────
  # For APIs that use OAuth2 client_credentials flow.
  # The script sends dummy client_id/client_secret to the /token endpoint,
  # ClawGuard replaces them with the real ones before forwarding.
  # stripe:
  #   upstream: https://api.stripe.com
  #   auth:
  #     type: oauth2_client_credentials
  #     token: "unused"
  #     tokenPath: /oauth/token                # where the script POSTs for tokens
  #     clientId: "ca_your-client-id"
  #     clientSecret: "sk_live_your-client-secret"
  #   policy:
  #     default: require_approval
  #     rules:
  #       - match: { method: GET }
  #         action: auto_approve
  #       - match: { method: POST, path: /oauth/token }
  #         action: auto_approve               # let token exchange pass through

  # ─── Anthropic (Claude API) ─────────────────────────────
  anthropic:
    upstream: https://api.anthropic.com
    auth:
      type: header
      headerName: x-api-key
      token: "sk-ant-your-api-key"
    policy:
      default: require_approval
      rules:
        - match: { method: POST, path: "/v1/messages" }
          action: require_approval           # API calls always need approval

  # ─── Slack ──────────────────────────────────────────────
  slack:
    upstream: https://slack.com/api
    hostnames:
      - slack.com
    auth:
      type: bearer
      token: "xoxb-your-slack-token"
    policy:
      default: require_approval

notifications:
  telegram:
    botToken: "${TELEGRAM_BOT_TOKEN}"
    chatId: "your-telegram-chat-id"
    pairing:
      enabled: true
      secret: "change-me-to-a-random-pairing-secret"  # IMPORTANT: openssl rand -hex 16

security:
  allowedUpstreams:
    - httpbin.org
    - api.github.com
    - api.openai.com
    - api.anthropic.com
    - api.stripe.com
    - slack.com
  blockPrivateIPs: true
  followRedirects: false
  maxPayloadLogSize: 10240

admin:
  enabled: true
  pin: "change-me"                          # IMPORTANT: quote it! YAML parses numbers as integers
  allowedIPs:
    - "127.0.0.1"
    - "::1"
    - "172.16.0.0/12"                       # Docker networks (172.16-31.x.x)
    # - "192.168.1.0/24"                    # uncomment to allow entire LAN
    # - "172.17.0.1"                        # Docker: host IP on default bridge network
    # - "172.16.0.0/12"                     # Docker: allow all Docker networks (172.16-31.x.x)

audit:
  type: sqlite
  path: ./data/clawguard.db    # use ./data/ for Docker volume persistence
  logPayload: false

# ─── HTTPS_PROXY mode (Mode C) ──────────────────────────────
# When enabled, ClawGuard also handles CONNECT requests on the same port.
# Your scripts don't need ANY changes — just set an env var:
#   export HTTPS_PROXY=http://YOUR_AGENT_KEY:x@clawguard-host:9090
#   export NODE_EXTRA_CA_CERTS=/path/to/data/ca/ca.crt
# ClawGuard intercepts TLS, applies approval policies, injects real tokens.
proxy:
  enabled: false
  caDir: ./data/ca              # CA cert/key stored here (auto-generated on first run)
  discovery: false              # MITM unknown hosts to detect auth patterns (see Discovered tab in dashboard)
